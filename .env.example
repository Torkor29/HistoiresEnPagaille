# Clé API Google Gemini (obligatoire) — NE JAMAIS exposer côté client
GEMINI_API_KEY=

# Base de données
# Dev : SQLite
DATABASE_URL="file:./dev.db"
# Prod : Postgres
# DATABASE_URL="postgresql://user:pass@host:5432/dbname"

# Stockage des fichiers
# Dev : stockage local (dossier uploads/)
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads

# Prod : S3 ou R2 (optionnel)
# STORAGE_PROVIDER=s3
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=  # pour R2

# Log
LOG_LEVEL=info

# Optionnel : URL de l'app (pour liens dans les emails / export)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Génération d'images (choix au moment de la génération) ---
# Gemini (défaut) : voir GEMINI_API_KEY ci-dessus.

# Replicate (cohérence de personnage, gratuit au début puis ~0,04 €/image)
# Créer un compte sur replicate.com et coller le token ici.
# REPLICATE_API_TOKEN=

# Local (Stable Diffusion sur votre PC) : voir docs/OPTION3-INSTALLATION.md pour installer Forge.
# Une fois Forge installé :
STABLE_DIFFUSION_URL=http://127.0.0.1:7860
# Chemin vers le dossier Forge (celui qui contient run.bat). Si défini, « npm run dev:all » lance Forge puis l'app.
# FORGE_PATH=C:\Users\Julie\Downloads\webui_forge_cu121_torch231
LOCAL_IMAGE_API_URL=http://localhost:8188/generate
